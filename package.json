{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev --hostname 127.0.0.1 --port 3000",
    "dev:turbo": "WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev --turbo --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "lint": "eslint .",
    "performance": "npm run build && npm run build:analyze",
    "optimize-images": "node scripts/optimize-images.js",
    "lighthouse": "npx lighthouse http://localhost:3000 --output-path ./lighthouse-report.html --save-assets --view"
  },
